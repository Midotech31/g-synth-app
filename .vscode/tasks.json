{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Reflex: run app",
      "detail": "Starts the Reflex dev server. Auto-runs when this workspace opens in Codespaces.",
      "type": "shell",
      "command": "cd reflex_poc && reflex run --frontend-port 3000 --backend-port 8000",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
