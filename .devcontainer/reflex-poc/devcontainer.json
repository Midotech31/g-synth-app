{
  "name": "G-Synth Reflex POC",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "task.allowAutomaticTasks": "on",
        "security.workspace.trust.startupPrompt": "never",
        "security.workspace.trust.enabled": false
      }
    },
    "codespaces": {
      "openFiles": [
        "reflex_poc/README.md"
      ]
    }
  },

  "postCreateCommand": "cd reflex_poc && pip install --upgrade pip && pip install -r requirements.txt && reflex init --template blank && echo 'Setup complete. The Reflex dev server will auto-start when VS Code opens this workspace.'",

  "forwardPorts": [3000, 8000],

  "portsAttributes": {
    "3000": {
      "label": "Reflex frontend (open this)",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Reflex backend",
      "onAutoForward": "silent"
    }
  },

  "remoteUser": "vscode"
}
